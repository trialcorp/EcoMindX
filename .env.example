# ── EcoMindX Carbon Platform — Environment Variables ──
# Copy to `.env` for local dev. NEVER commit a real `.env`.

# Supabase Configuration (Required for Community & Auth features)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini API Key (Required for AI Insights)
# If omitted, the app will gracefully fall back to the local deterministic rule engine.
GEMINI_API_KEY=your-gemini-key

# Optional: Disable AI integration entirely for local testing
USE_GEMINI=true
